APP_NAME="Notification Service"
APP_ENV=testing
APP_KEY=base64:R1TfvRak2jZAGysUWJbeQ4pPkVyQyA1eXUXUgV5snoU=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notifications
DB_USERNAME=postgres
DB_PASSWORD=postgres

REDIS_CLIENT=predis
REDIS_HOST=redis
